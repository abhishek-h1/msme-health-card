# Anthropic API key, used by backend/agents/ for the risk/recommendation/narrative
# LLM pipeline. ANTHROPIC_API_KEY also works (the SDK's native env var name) --
# either is read.
LLM_API_KEY=your_api_key_here
DATABASE_URL=sqlite:///./msme_health.db

# Comma-separated extra CORS origins to allow beyond localhost:3000, e.g. your
# deployed frontend: https://your-app.vercel.app
ALLOWED_ORIGINS=
